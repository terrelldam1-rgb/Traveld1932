{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://trip-host.preview.emergentagent.com"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://your-production-api.example.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://your-production-api.example.com"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "terrelldam1@gmail.com",
        "ascAppId": "REPLACE-WITH-APP-STORE-CONNECT-APP-ID",
        "appleTeamId": "REPLACE-WITH-APPLE-TEAM-ID"
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "internal"
      }
    }
  }
}
